# Microsoft Entra ID (rett.es tenant)
AZURE_TENANT_ID=your-rett-es-tenant-id
ENTRA_API_CLIENT_ID=your-api-app-registration-client-id

# Azure Cosmos DB
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_DATABASE_NAME=opentreasury
COSMOS_KEY=your-cosmos-primary-key-for-local-dev-only
# For Cosmos Emulator local dev, you can instead use:
# COSMOS_ENDPOINT=https://localhost:8081/
# COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==

# CORS
CORS_ORIGINS=["http://localhost:4200"]

# ----------------------------------------------------------------------
# Repository backend (Phase A — Electron + SQLite spec §4.2)
# ----------------------------------------------------------------------
# `cosmos` (default) keeps existing cloud behavior. `sqlite` activates
# the desktop repository implementations. Phase A ships only the
# scaffolding for `sqlite`; the desktop runtime is delivered in later
# phases (B–E).
DATA_BACKEND=cosmos

# Path to the SQLite database file (only used when DATA_BACKEND=sqlite).
# May be a local path (Local mode) or a OneDrive-synced path (Team mode).
SQLITE_DB_PATH=opentreasury.db
