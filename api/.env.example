# Microsoft Entra ID
AZURE_TENANT_ID=your-entra-tenant-id
ENTRA_API_CLIENT_ID=your-api-app-registration-client-id

# Azure Cosmos DB
# Auth: leave COSMOS_KEY empty — uses Entra ID RBAC (Managed Identity in prod, az login locally).
# For local dev, run: az login — and ensure your Entra object ID has the Cosmos DB Built-in Data
# Contributor role assigned (see docs/guides/azure-setup.md).
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_DATABASE_NAME=opentreasury
COSMOS_KEY=

# CORS
CORS_ORIGINS=["http://localhost:4200"]
